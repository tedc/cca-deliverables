# Neon Postgres connection string (use the pooled connection string for serverless)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Admin credentials — the only user of the app (single-user)
ADMIN_EMAIL=edo@example.com
ADMIN_PASSWORD=changeme-strong-password
ADMIN_NAME=Edo

# Better Auth secret (generate a random 32+ char string, e.g. `openssl rand -base64 32`)
AUTH_SECRET=replace-with-random-32-char-string

# Public base URL of the app
NEXT_PUBLIC_APP_URL=http://localhost:3000
